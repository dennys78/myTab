# Copia su server:  cp .env.production.example .env
# Poi modifica i valori CHANGE_ME e:  docker compose up -d
# Il file .env non va committato (è in .gitignore).

# Genera chiave:  openssl rand -hex 32
DJANGO_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

DJANGO_DEBUG=false

# Cloudflare / dominio pubblico
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,serverapp.asuscomm.com,www.mytab.uk,mytab.uk
CSRF_TRUSTED_ORIGINS=http://serverapp.asuscomm.com:8080,https://www.mytab.uk,https://mytab.uk
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Creati solo al PRIMO avvio se il DB non ha ancora utenti (ensure_admin)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_password_sicura
DJANGO_SUPERUSER_EMAIL=admin@mytab.uk

# Opzionali — acquisizione IA (dashboard Impostazioni può sovrascriverle)
GROQ_API_KEY=
GEMINI_API_KEY=

# Bot Telegram (se usi telegram_bot)
# TELEGRAM_BOT_TOKEN=
